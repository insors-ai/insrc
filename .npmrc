# Pin daemon native module builds to Node 22.22.1 headers, regardless of
# which Node version actually runs `npm install`.
#
# Why: tree-sitter@0.25's binding.gyp pins -std=c++17, but Node 24's V8
# headers require C++20 (v8config.h: `error: "C++20 or later required."`).
# Building under Node 24 breaks the install on Macs where Homebrew's
# default `node` is 24.x. We avoid that by telling node-gyp to download
# Node 22.22.1 headers and target those, no matter what `node -v` reports
# at install time.
#
# The daemon runs under Node 22 too (see resolveCommand('node') in
# insrcDaemonMainService.ts and the project's .nvmrc), so build and
# runtime ABIs stay in lockstep at modules=127 / napi=10.
#
# We deliberately do NOT set `build_from_source=true`. That would force
# every native dep to build from source even when an ABI-correct prebuild
# exists -- and some packages (e.g. @parcel/watcher) ship prebuilds via
# per-platform sibling packages and have binding.gyps that drop -std=c++17
# from cflags, so source-builds fail on macOS Apple-Clang. Letting prebuild
# lookups succeed where they can keeps the install path resilient.
target="22.22.1"
runtime="node"
disturl="https://nodejs.org/dist"
legacy-peer-deps="true"
